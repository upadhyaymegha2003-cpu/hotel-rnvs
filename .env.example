# Replace these values before deploying.
AUTH_SECRET="replace-with-a-long-random-secret"
ROOM_TOKEN_SECRET="replace-with-a-separate-long-random-secret"
STAFF_USERNAME="concierge"
STAFF_PASSWORD="concierge-demo"

# Optional locally. Required for shared rate limits and realtime delivery when
# running more than one app instance.
REDIS_URL="redis://localhost:6379"

# Plain /room/204 URLs are convenient locally. Leave false in production and
# generate signed links via POST /api/room-links while logged in as staff.
ALLOW_UNSIGNED_ROOM_LINKS="true"
