// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model Request {
  id          String   @id @default(cuid())
  roomId      String
  customText  String?
  status      String   @default("PENDING")
  seenByStaff Boolean  @default(false)
  assignedTo  String?
  version     Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  items       RequestItem[]
  auditLogs   AuditLog[]

  @@index([roomId])
  @@index([status])
  @@index([createdAt])
}

model RequestItem {
  id          String  @id @default(cuid())
  requestId   String
  type        String
  emoji       String
  label       String
  description String
  request     Request @relation(fields: [requestId], references: [id], onDelete: Cascade)

  @@unique([requestId, type])
  @@index([type])
}

model AuditLog {
  id        String   @id @default(cuid())
  requestId String
  action    String
  actor     String
  metadata  String?
  createdAt DateTime @default(now())
  request   Request  @relation(fields: [requestId], references: [id], onDelete: Cascade)

  @@index([requestId, createdAt])
}
